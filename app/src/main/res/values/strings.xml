    <string name="feat_sync_title">Record Together</string>
    <string name="feat_sync_desc">You and your partner can record expenses from your respective phones</string>
    <string name="feat_night_title">Automatic Night Mode</string>
    <string name="feat_night_desc">Dark theme adjusts to sunrise &amp; sunset time at your location</string>
    <string name="feat_stat_title">Visual Statistics</string>
    <string name="feat_stat_desc">See expense breakdown per category with beautiful charts</string>
    <string name="feat_target_title">Monthly Target</string>
    <string name="feat_target_desc">Set budget and monitor if spending is still within limits</string>
    <string name="feat_weather_title">Weather Info</string>
    <string name="feat_weather_desc">Greeting and real-time weather info every time you open the app</string>
